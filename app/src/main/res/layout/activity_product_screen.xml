<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ProductScreen"
    android:orientation="vertical"
    android:background="#232121"
    >

    <LinearLayout
        android:layout_width="390dp"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:background="@drawable/myname_bg"
        >


        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="John Dexter V. Cullados"
            android:fontFamily="@font/aboreto"
            android:textStyle="bold"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="8dp"
            android:textColor="#000000"
            />

        <TextView
            android:id="@+id/textView2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activity #8"
            android:fontFamily="@font/aboreto"
            android:textStyle="bold"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="8dp"
            android:textColor="#000000"
            />

    </LinearLayout>

    <ScrollView
        android:layout_width="390dp"
        android:layout_height="580dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:background="@drawable/myname_bg"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="vertical"
            >

            <!-- first product -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgProduct1"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/porsche" />

                    <TextView
                        android:id="@+id/txtName1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Porsche 911 GT3 RS"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="@font/black_ops_one"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/txtPrice1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱48,000"
                        android:textColor="#D4AF37"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/status1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:text="RETIRED - SEALED"
                        android:textColor="#49A809"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/btnAddToCart1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ADD TO CART"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#D4AF37"
                        android:textColor="#000000" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- second product -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgProduct2"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bugatti" />

                    <TextView
                        android:id="@+id/txtName2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bugatti Chiron"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="@font/black_ops_one"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/txtPrice2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱32,000"
                        android:textColor="#D4AF37"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/status2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:text="RETIRED - OPENED"
                        android:textColor="#49A809"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/btnAddToCart2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ADD TO CART"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#D4AF37"
                        android:textColor="#000000" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- third product -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgProduct3"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/lambo" />

                    <TextView
                        android:id="@+id/txtName3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lambo Sián"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="@font/black_ops_one"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/txtPrice3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₱28,000"
                        android:textColor="#D4AF37"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/status3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:text="SEALED"
                        android:textColor="#49A809"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/btnAddToCart3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ADD TO CART"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#D4AF37"
                        android:textColor="#000000" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>


    </ScrollView>

    <LinearLayout
        android:layout_width="390dp"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:layout_gravity="center"
        android:gravity="center"

        >


        <Button
            android:id="@+id/btnGotocategory"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="20dp"
            android:text="Categories"
            android:textColor="#ffffff"
            android:fontFamily="@font/black_ops_one"
            android:background="@drawable/button_bg"
            app:backgroundTint="@null"
            />
        <Button
            android:id="@+id/btnCart"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="View Cart"
            android:textColor="#ffffff"
            android:fontFamily="@font/black_ops_one"
            android:background="@drawable/button_bg"
            app:backgroundTint="@null"
            />

    </LinearLayout>


</LinearLayout>