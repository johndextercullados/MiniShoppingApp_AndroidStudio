<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#232121"
    tools:context=".MainActivity">


    <LinearLayout
        android:layout_width="390dp"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:background="@drawable/myname_bg"
        >


        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="John Dexter V. Cullados"
            android:fontFamily="@font/aboreto"
            android:textStyle="bold"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="8dp"
            android:textColor="#000000"
            />

        <TextView
            android:id="@+id/textView2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activity #8"
            android:fontFamily="@font/aboreto"
            android:textStyle="bold"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="8dp"
            android:textColor="#000000"
            />

    </LinearLayout>

    <LinearLayout
        android:layout_width="390dp"
        android:layout_height="630dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:background="@drawable/myname_bg"
        >


        <ImageView
            android:id="@+id/imageView"
            android:layout_width="300dp"
            android:layout_height="300dp"
            app:srcCompat="@drawable/brickvaultlogo"
            />

        <TextView
            android:id="@+id/textView3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/black_ops_one"
            android:textSize="40dp"
            android:gravity="center"
            android:text="BRICK VAULT"
            android:textColor="#D9D2D2"
            />

        <TextView
            android:id="@+id/textView4"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:text="Unlocking memories, one brick at a time. A place where legendary sets find new homes"
            android:gravity="center"
            android:textColor="#D9D2D2"
            android:textSize="10dp"
            android:fontFamily="@font/aboreto"
            android:textStyle="bold"
            />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"
            android:background="@drawable/linebreak" />


        <TextView
            android:id="@+id/textView5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aclonica"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:text="Collector's Name: "
            android:textColor="#D9D2D2"
            android:textSize="15dp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editTextText"
            android:layout_width="300dp"
            android:layout_height="45dp"
            android:ems="10"
            android:layout_marginTop="8dp"
            android:inputType="text"
            android:text="Name"
            android:fontFamily="@font/aclonica"
            android:textColor="#D9D2D2"
            android:textSize="30dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:background="@drawable/inputname"
            />

        <Button
            android:id="@+id/button"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textSize="20dp"
            android:text="Unclock Vault"
            android:background="@drawable/button_bg"
            app:backgroundTint="@null"
            android:fontFamily="@font/black_ops_one"
            android:textColor="#D9D2D2"
            />


    </LinearLayout>


</LinearLayout>